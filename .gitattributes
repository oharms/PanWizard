# Auto-detect text files and normalize line endings
* text=auto

# Force LF for shell scripts and JS source
*.js text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sh text eol=lf
scripts/git-hooks/* text eol=lf

# Binary files
*.svg binary
*.png binary
*.ico binary
